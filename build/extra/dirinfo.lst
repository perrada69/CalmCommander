# file opened: extra\dirinfo.asm
   1  0000              ; -----------------------------------------------------------------------------
   2  0000              ; .dirinfo - standalone NextZXOS dot command
   3  0000              ; -----------------------------------------------------------------------------
   4  0000              ; Shows recursive information about a file or directory. The command is intended
   5  0000              ; as a small companion to Calm Commander: it accepts quoted paths, uses LFN
   6  0000              ; directory reads, can be cancelled with BREAK, and avoids ROM CLS/scroll prompts.
   7  0000              ; -----------------------------------------------------------------------------
   8  0000
