# file opened: copy.asm
   1  0000              ; -----------------------------------------------------------------------------
   2  0000              ; .copy - standalone NextZXOS dot command
   3  0000              ; -----------------------------------------------------------------------------
   4  0000              ; Copies or moves files/directories using the esxDOS-compatible API.
   5  0000              ; This file was split from the Calm Commander syscopy plugin, but runs as a
   6  0000              ; normal dot command at $2000. Because dot commands execute in a special DOS
   7  0000              ; environment, pointers passed to RST $08 use HL, not IX.
   8  0000              ; -----------------------------------------------------------------------------
   9  0000
  10  0000                      DEVICE ZXSPECTRUMNEXT
  11  0000                      org $2000
  12  2000
  13  2000                      include "../plugin/syscopy_api.i.asm"
