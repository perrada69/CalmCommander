  62  2000              ; Runtime work area. Path stacks hold one 256-byte path per recursion level.
  63  2000              ; The copy buffer is deliberately above DIR_ENTRY/LFN_ENTRY so file I/O cannot
  64  2000              ; overwrite the directory entry currently being processed.
  65  2000              SRC_STACK        equ $C000                         ; 12 * 256 bytes
  66  2000              DST_STACK        equ $CC00                         ; 12 * 256 bytes
  67  2000              DIR_ENTRY        equ $D800                         ; 512 bytes
  68  2000              LFN_ENTRY        equ $DA00                         ; 512 bytes
