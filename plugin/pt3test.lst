 484  C3EB                      include "ptx_vtpl.i.asm"
# file opened: ptx_vtpl.i.asm
   1+ C3EB              ;Universal PT2'n'PT3 Turbo Sound player for ZX Spectrum
   2+ C3EB              ;(c)2004-2007 S.V.Bulba <vorobey@mail.khstu.ru>
   3+ C3EB              ;Specially for AlCo
   4+ C3EB              ;http://bulba.untergrund.net/ (http://bulba.at.kz/)
   5+ C3EB              	MODULE VTPL
   6+ C3EB              ;Release number
   7+ C3EB              Release EQU "0"
   8+ C3EB              ;Conditional assembly
   9+ C3EB              ;1) Current position counters at (Vars1+0) and (Vars2+0)
  10+ C3EB              CurPosCounter=0
  11+ C3EB              ;2) Allow channels allocation bits at (START+10)
  12+ C3EB              ACBBAC=0
  13+ C3EB              ;3) Allow loop checking and disabling
  14+ C3EB              LoopChecker=1
  15+ C3EB              ;4) Insert official identificator
  16+ C3EB              Id=0
  17+ C3EB              ;5) Set IY for correct return to ZX Basic
  18+ C3EB              Basic=1
  19+ C3EB
  20+ C3EB              ;Features
  21+ C3EB              ;--------
  22+ C3EB              ;-Can be compiled at any address (i.e. no need rounding ORG
  23+ C3EB              ; address).
  24+ C3EB              ;-Variables (VARS) can be located at any address (not only after
  25+ C3EB              ; code block).
  26+ C3EB              ;-INIT subprogram checks PT3-module version and rightly
  27+ C3EB              ; generates both note and volume tables outside of code block
  28+ C3EB              ; (in VARS).
  29+ C3EB              ;-Two portamento (spc. command 3xxx) algorithms (depending of
  30+ C3EB              ; PT3 module version).
  31+ C3EB              ;-New 1.XX and 2.XX special command behaviour (only for PT v3.7
  32+ C3EB              ; and higher).
  33+ C3EB              ;-Any Tempo value are accepted (including Tempo=1 and Tempo=2).
  34+ C3EB              ;-TS modes: 2xPT3, 2xPT2 and PT v3.7 TS standard.
  35+ C3EB              ;-Fully compatible with Ay_Emul PT3 and PT2 players codes.
  36+ C3EB              ;-See also notes at the end of this source code.
  37+ C3EB
  38+ C3EB              ;Limitations
  39+ C3EB              ;-----------
  40+ C3EB              ;-Can run in RAM only (self-modified code is used).
  41+ C3EB              ;-PT2 position list must be end by #FF marker only.
  42+ C3EB
  43+ C3EB              ;Warning!!! PLAY subprogram can crash if no module are loaded
  44+ C3EB              ;into RAM or INIT subprogram was not called before.
  45+ C3EB
  46+ C3EB              ;Call MUTE or INIT one more time to mute sound after stopping
  47+ C3EB              ;playing
  48+ C3EB
  49+ C3EB              ;Test codes (commented)
  50+ C3EB              ;	LD A,32 ;SinglePT3(TS if TSPT3.7),ABC,Looped
  51+ C3EB              ;	LD (START+10),A
  52+ C3EB              ;	LD HL,#8000 ;Mod1
  53+ C3EB              ;	LD DE,#A000 ;Mod2 (optional)
  54+ C3EB              ;	CALL START+3
  55+ C3EB              ;	EI
  56+ C3EB              ;_LP	HALT
  57+ C3EB              ;	CALL START+5
  58+ C3EB              ;	XOR A
  59+ C3EB              ;	IN A,(#FE)
  60+ C3EB              ;	CPL
  61+ C3EB              ;	AND 15
  62+ C3EB              ;	JR Z,_LP
  63+ C3EB              ;	JR START+8
  64+ C3EB
  65+ C3EB              TonA	EQU 0
  66+ C3EB              TonB	EQU 2
  67+ C3EB              TonC	EQU 4
  68+ C3EB              Noise	EQU 6
  69+ C3EB              Mixer	EQU 7
  70+ C3EB              AmplA	EQU 8
  71+ C3EB              AmplB	EQU 9
  72+ C3EB              AmplC	EQU 10
  73+ C3EB              Env	EQU 11
  74+ C3EB              EnvTp	EQU 13
  75+ C3EB
  76+ C3EB              ;Entry and other points
  77+ C3EB              ;START initialize playing of modules at MDLADDR (single module)
  78+ C3EB              ;START+3 initialization with module address in HL and DE (TS)
  79+ C3EB              ;START+5 play one quark
  80+ C3EB              ;START+8 mute
  81+ C3EB              ;START+10 setup and status flags
  82+ C3EB
  83+ C3EB              START:
  84+ C3EB 21 00 40     	LD HL,songdata ;DE - address of 2nd module for TS
  85+ C3EE 18 3C        	JR INIT
  86+ C3F0 C3 4F CC     	JP PLAY
  87+ C3F3 18 25        	JR MUTE
  88+ C3F5 10           SETUP	DB %00010000 ;set bit0, if you want to play without looping
  89+ C3F6              	     ;(optional);
  90+ C3F6              	     ;set bit1 for PT2 and reset for PT3 before
  91+ C3F6              	     ;calling INIT;
  92+ C3F6              	     ;bits2-3: %00-ABC, %01-ACB, %10-BAC (optional);
  93+ C3F6              	     ;bits4-5: %00-no TS, %01-2 modules TS, %10-
  94+ C3F6              	     ;autodetect PT3 TS-format by AlCo (PT 3.7+);
  95+ C3F6              	     ;Remark: old PT3 TS-format by AlCo (PT 3.6) is not
  96+ C3F6              	     ;documented and must be converted to new standard.
  97+ C3F6              	     ;bit6 is set each time, when loop point of 2nd TS
  98+ C3F6              	     ;module is passed (optional).
  99+ C3F6              	     ;bit7 is set each time, when loop point of 1st TS
 100+ C3F6              	     ;or of single module is passed (optional).
 101+ C3F6
 102+ C3F6              ;Identifier
 103+ C3F6              	IF Id
