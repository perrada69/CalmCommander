# file opened: plugin\ptx_vtpl.i.asm
   1+ C1E5              ;Universal PT2'n'PT3 Turbo Sound player for ZX Spectrum
   2+ C1E5              ;(c)2004-2007 S.V.Bulba <vorobey@mail.khstu.ru>
   3+ C1E5              ;Specially for AlCo
   4+ C1E5              ;http://bulba.untergrund.net/ (http://bulba.at.kz/)
   5+ C1E5              	MODULE VTPL
   6+ C1E5              ;Release number
   7+ C1E5              Release EQU "0"
   8+ C1E5              ;Conditional assembly
   9+ C1E5              ;1) Current position counters at (Vars1+0) and (Vars2+0)
  10+ C1E5              CurPosCounter=0
  11+ C1E5              ;2) Allow channels allocation bits at (START+10)
  12+ C1E5              ACBBAC=0
  13+ C1E5              ;3) Allow loop checking and disabling
  14+ C1E5              LoopChecker=1
  15+ C1E5              ;4) Insert official identificator
  16+ C1E5              Id=0
  17+ C1E5              ;5) Set IY for correct return to ZX Basic
  18+ C1E5              Basic=1
  19+ C1E5
  20+ C1E5              ;Features
  21+ C1E5              ;--------
  22+ C1E5              ;-Can be compiled at any address (i.e. no need rounding ORG
  23+ C1E5              ; address).
  24+ C1E5              ;-Variables (VARS) can be located at any address (not only after
  25+ C1E5              ; code block).
  26+ C1E5              ;-INIT subprogram checks PT3-module version and rightly
  27+ C1E5              ; generates both note and volume tables outside of code block
  28+ C1E5              ; (in VARS).
  29+ C1E5              ;-Two portamento (spc. command 3xxx) algorithms (depending of
  30+ C1E5              ; PT3 module version).
  31+ C1E5              ;-New 1.XX and 2.XX special command behaviour (only for PT v3.7
  32+ C1E5              ; and higher).
  33+ C1E5              ;-Any Tempo value are accepted (including Tempo=1 and Tempo=2).
  34+ C1E5              ;-TS modes: 2xPT3, 2xPT2 and PT v3.7 TS standard.
  35+ C1E5              ;-Fully compatible with Ay_Emul PT3 and PT2 players codes.
  36+ C1E5              ;-See also notes at the end of this source code.
  37+ C1E5
  38+ C1E5              ;Limitations
  39+ C1E5              ;-----------
  40+ C1E5              ;-Can run in RAM only (self-modified code is used).
  41+ C1E5              ;-PT2 position list must be end by #FF marker only.
  42+ C1E5
  43+ C1E5              ;Warning!!! PLAY subprogram can crash if no module are loaded
  44+ C1E5              ;into RAM or INIT subprogram was not called before.
  45+ C1E5
  46+ C1E5              ;Call MUTE or INIT one more time to mute sound after stopping
  47+ C1E5              ;playing
  48+ C1E5
  49+ C1E5              ;Test codes (commented)
  50+ C1E5              ;	LD A,32 ;SinglePT3(TS if TSPT3.7),ABC,Looped
  51+ C1E5              ;	LD (START+10),A
  52+ C1E5              ;	LD HL,#8000 ;Mod1
  53+ C1E5              ;	LD DE,#A000 ;Mod2 (optional)
  54+ C1E5              ;	CALL START+3
  55+ C1E5              ;	EI
  56+ C1E5              ;_LP	HALT
  57+ C1E5              ;	CALL START+5
  58+ C1E5              ;	XOR A
  59+ C1E5              ;	IN A,(#FE)
  60+ C1E5              ;	CPL
  61+ C1E5              ;	AND 15
  62+ C1E5              ;	JR Z,_LP
  63+ C1E5              ;	JR START+8
  64+ C1E5
  65+ C1E5              TonA	EQU 0
  66+ C1E5              TonB	EQU 2
  67+ C1E5              TonC	EQU 4
  68+ C1E5              Noise	EQU 6
  69+ C1E5              Mixer	EQU 7
  70+ C1E5              AmplA	EQU 8
  71+ C1E5              AmplB	EQU 9
  72+ C1E5              AmplC	EQU 10
  73+ C1E5              Env	EQU 11
  74+ C1E5              EnvTp	EQU 13
  75+ C1E5
  76+ C1E5              ;Entry and other points
  77+ C1E5              ;START initialize playing of modules at MDLADDR (single module)
  78+ C1E5              ;START+3 initialization with module address in HL and DE (TS)
  79+ C1E5              ;START+5 play one quark
  80+ C1E5              ;START+8 mute
  81+ C1E5              ;START+10 setup and status flags
  82+ C1E5
  83+ C1E5              START:
  84+ C1E5 21 00 40     	LD HL,songdata ;DE - address of 2nd module for TS
  85+ C1E8 18 3C        	JR INIT
  86+ C1EA C3 49 CA     	JP PLAY
  87+ C1ED 18 25        	JR MUTE
  88+ C1EF 10           SETUP	DB %00010000 ;set bit0, if you want to play without looping
  89+ C1F0              	     ;(optional);
  90+ C1F0              	     ;set bit1 for PT2 and reset for PT3 before
  91+ C1F0              	     ;calling INIT;
  92+ C1F0              	     ;bits2-3: %00-ABC, %01-ACB, %10-BAC (optional);
  93+ C1F0              	     ;bits4-5: %00-no TS, %01-2 modules TS, %10-
  94+ C1F0              	     ;autodetect PT3 TS-format by AlCo (PT 3.7+);
  95+ C1F0              	     ;Remark: old PT3 TS-format by AlCo (PT 3.6) is not
  96+ C1F0              	     ;documented and must be converted to new standard.
  97+ C1F0              	     ;bit6 is set each time, when loop point of 2nd TS
  98+ C1F0              	     ;module is passed (optional).
  99+ C1F0              	     ;bit7 is set each time, when loop point of 1st TS
 100+ C1F0              	     ;or of single module is passed (optional).
 101+ C1F0
 102+ C1F0              ;Identifier
 103+ C1F0              	IF Id
 104+ C1F0 ~            	DB "=UniPT2/PT3/TS-Player r.",Release,"="
 105+ C1F0              	ENDIF
