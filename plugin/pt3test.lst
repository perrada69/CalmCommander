 482  C3FF                      include "ptx_vtpl.i.asm"
# file opened: ptx_vtpl.i.asm
   1+ C3FF              ;Universal PT2'n'PT3 Turbo Sound player for ZX Spectrum
   2+ C3FF              ;(c)2004-2007 S.V.Bulba <vorobey@mail.khstu.ru>
   3+ C3FF              ;Specially for AlCo
   4+ C3FF              ;http://bulba.untergrund.net/ (http://bulba.at.kz/)
   5+ C3FF              	MODULE VTPL
   6+ C3FF              ;Release number
   7+ C3FF              Release EQU "0"
   8+ C3FF              ;Conditional assembly
   9+ C3FF              ;1) Current position counters at (Vars1+0) and (Vars2+0)
  10+ C3FF              CurPosCounter=0
  11+ C3FF              ;2) Allow channels allocation bits at (START+10)
  12+ C3FF              ACBBAC=0
  13+ C3FF              ;3) Allow loop checking and disabling
  14+ C3FF              LoopChecker=1
  15+ C3FF              ;4) Insert official identificator
  16+ C3FF              Id=0
  17+ C3FF              ;5) Set IY for correct return to ZX Basic
  18+ C3FF              Basic=1
  19+ C3FF
  20+ C3FF              ;Features
  21+ C3FF              ;--------
  22+ C3FF              ;-Can be compiled at any address (i.e. no need rounding ORG
  23+ C3FF              ; address).
  24+ C3FF              ;-Variables (VARS) can be located at any address (not only after
  25+ C3FF              ; code block).
  26+ C3FF              ;-INIT subprogram checks PT3-module version and rightly
  27+ C3FF              ; generates both note and volume tables outside of code block
  28+ C3FF              ; (in VARS).
  29+ C3FF              ;-Two portamento (spc. command 3xxx) algorithms (depending of
  30+ C3FF              ; PT3 module version).
  31+ C3FF              ;-New 1.XX and 2.XX special command behaviour (only for PT v3.7
  32+ C3FF              ; and higher).
  33+ C3FF              ;-Any Tempo value are accepted (including Tempo=1 and Tempo=2).
  34+ C3FF              ;-TS modes: 2xPT3, 2xPT2 and PT v3.7 TS standard.
  35+ C3FF              ;-Fully compatible with Ay_Emul PT3 and PT2 players codes.
  36+ C3FF              ;-See also notes at the end of this source code.
  37+ C3FF
  38+ C3FF              ;Limitations
  39+ C3FF              ;-----------
  40+ C3FF              ;-Can run in RAM only (self-modified code is used).
  41+ C3FF              ;-PT2 position list must be end by #FF marker only.
  42+ C3FF
  43+ C3FF              ;Warning!!! PLAY subprogram can crash if no module are loaded
  44+ C3FF              ;into RAM or INIT subprogram was not called before.
  45+ C3FF
  46+ C3FF              ;Call MUTE or INIT one more time to mute sound after stopping
  47+ C3FF              ;playing
  48+ C3FF
  49+ C3FF              ;Test codes (commented)
  50+ C3FF              ;	LD A,32 ;SinglePT3(TS if TSPT3.7),ABC,Looped
  51+ C3FF              ;	LD (START+10),A
  52+ C3FF              ;	LD HL,#8000 ;Mod1
  53+ C3FF              ;	LD DE,#A000 ;Mod2 (optional)
  54+ C3FF              ;	CALL START+3
  55+ C3FF              ;	EI
  56+ C3FF              ;_LP	HALT
  57+ C3FF              ;	CALL START+5
  58+ C3FF              ;	XOR A
  59+ C3FF              ;	IN A,(#FE)
  60+ C3FF              ;	CPL
  61+ C3FF              ;	AND 15
  62+ C3FF              ;	JR Z,_LP
  63+ C3FF              ;	JR START+8
  64+ C3FF
  65+ C3FF              TonA	EQU 0
  66+ C3FF              TonB	EQU 2
  67+ C3FF              TonC	EQU 4
  68+ C3FF              Noise	EQU 6
  69+ C3FF              Mixer	EQU 7
  70+ C3FF              AmplA	EQU 8
  71+ C3FF              AmplB	EQU 9
  72+ C3FF              AmplC	EQU 10
  73+ C3FF              Env	EQU 11
  74+ C3FF              EnvTp	EQU 13
  75+ C3FF
  76+ C3FF              ;Entry and other points
  77+ C3FF              ;START initialize playing of modules at MDLADDR (single module)
  78+ C3FF              ;START+3 initialization with module address in HL and DE (TS)
  79+ C3FF              ;START+5 play one quark
  80+ C3FF              ;START+8 mute
  81+ C3FF              ;START+10 setup and status flags
  82+ C3FF
  83+ C3FF              START:
  84+ C3FF 21 00 40     	LD HL,songdata ;DE - address of 2nd module for TS
  85+ C402 18 3C        	JR INIT
  86+ C404 C3 63 CC     	JP PLAY
  87+ C407 18 25        	JR MUTE
  88+ C409 10           SETUP	DB %00010000 ;set bit0, if you want to play without looping
  89+ C40A              	     ;(optional);
  90+ C40A              	     ;set bit1 for PT2 and reset for PT3 before
  91+ C40A              	     ;calling INIT;
  92+ C40A              	     ;bits2-3: %00-ABC, %01-ACB, %10-BAC (optional);
  93+ C40A              	     ;bits4-5: %00-no TS, %01-2 modules TS, %10-
  94+ C40A              	     ;autodetect PT3 TS-format by AlCo (PT 3.7+);
  95+ C40A              	     ;Remark: old PT3 TS-format by AlCo (PT 3.6) is not
  96+ C40A              	     ;documented and must be converted to new standard.
  97+ C40A              	     ;bit6 is set each time, when loop point of 2nd TS
  98+ C40A              	     ;module is passed (optional).
  99+ C40A              	     ;bit7 is set each time, when loop point of 1st TS
 100+ C40A              	     ;or of single module is passed (optional).
