 502  C40A                      include "ptx_vtpl.i.asm"
# file opened: plugin\ptx_vtpl.i.asm
   1+ C40A              ;Universal PT2'n'PT3 Turbo Sound player for ZX Spectrum
   2+ C40A              ;(c)2004-2007 S.V.Bulba <vorobey@mail.khstu.ru>
   3+ C40A              ;Specially for AlCo
   4+ C40A              ;http://bulba.untergrund.net/ (http://bulba.at.kz/)
   5+ C40A              	MODULE VTPL
   6+ C40A              ;Release number
   7+ C40A              Release EQU "0"
   8+ C40A              ;Conditional assembly
   9+ C40A              ;1) Current position counters at (Vars1+0) and (Vars2+0)
  10+ C40A              CurPosCounter=0
  11+ C40A              ;2) Allow channels allocation bits at (START+10)
  12+ C40A              ACBBAC=0
  13+ C40A              ;3) Allow loop checking and disabling
  14+ C40A              LoopChecker=1
  15+ C40A              ;4) Insert official identificator
  16+ C40A              Id=0
  17+ C40A              ;5) Set IY for correct return to ZX Basic
  18+ C40A              Basic=1
  19+ C40A
  20+ C40A              ;Features
  21+ C40A              ;--------
  22+ C40A              ;-Can be compiled at any address (i.e. no need rounding ORG
  23+ C40A              ; address).
  24+ C40A              ;-Variables (VARS) can be located at any address (not only after
  25+ C40A              ; code block).
  26+ C40A              ;-INIT subprogram checks PT3-module version and rightly
  27+ C40A              ; generates both note and volume tables outside of code block
  28+ C40A              ; (in VARS).
  29+ C40A              ;-Two portamento (spc. command 3xxx) algorithms (depending of
  30+ C40A              ; PT3 module version).
  31+ C40A              ;-New 1.XX and 2.XX special command behaviour (only for PT v3.7
  32+ C40A              ; and higher).
  33+ C40A              ;-Any Tempo value are accepted (including Tempo=1 and Tempo=2).
  34+ C40A              ;-TS modes: 2xPT3, 2xPT2 and PT v3.7 TS standard.
  35+ C40A              ;-Fully compatible with Ay_Emul PT3 and PT2 players codes.
  36+ C40A              ;-See also notes at the end of this source code.
  37+ C40A
  38+ C40A              ;Limitations
  39+ C40A              ;-----------
  40+ C40A              ;-Can run in RAM only (self-modified code is used).
  41+ C40A              ;-PT2 position list must be end by #FF marker only.
  42+ C40A
  43+ C40A              ;Warning!!! PLAY subprogram can crash if no module are loaded
  44+ C40A              ;into RAM or INIT subprogram was not called before.
  45+ C40A
  46+ C40A              ;Call MUTE or INIT one more time to mute sound after stopping
  47+ C40A              ;playing
  48+ C40A
  49+ C40A              ;Test codes (commented)
  50+ C40A              ;	LD A,32 ;SinglePT3(TS if TSPT3.7),ABC,Looped
  51+ C40A              ;	LD (START+10),A
  52+ C40A              ;	LD HL,#8000 ;Mod1
  53+ C40A              ;	LD DE,#A000 ;Mod2 (optional)
  54+ C40A              ;	CALL START+3
  55+ C40A              ;	EI
  56+ C40A              ;_LP	HALT
  57+ C40A              ;	CALL START+5
  58+ C40A              ;	XOR A
  59+ C40A              ;	IN A,(#FE)
  60+ C40A              ;	CPL
  61+ C40A              ;	AND 15
  62+ C40A              ;	JR Z,_LP
  63+ C40A              ;	JR START+8
  64+ C40A
  65+ C40A              TonA	EQU 0
  66+ C40A              TonB	EQU 2
  67+ C40A              TonC	EQU 4
  68+ C40A              Noise	EQU 6
  69+ C40A              Mixer	EQU 7
  70+ C40A              AmplA	EQU 8
  71+ C40A              AmplB	EQU 9
  72+ C40A              AmplC	EQU 10
  73+ C40A              Env	EQU 11
  74+ C40A              EnvTp	EQU 13
  75+ C40A
  76+ C40A              ;Entry and other points
  77+ C40A              ;START initialize playing of modules at MDLADDR (single module)
  78+ C40A              ;START+3 initialization with module address in HL and DE (TS)
  79+ C40A              ;START+5 play one quark
  80+ C40A              ;START+8 mute
  81+ C40A              ;START+10 setup and status flags
  82+ C40A
  83+ C40A              START:
  84+ C40A 21 00 40     	LD HL,songdata ;DE - address of 2nd module for TS
  85+ C40D 18 3C        	JR INIT
  86+ C40F C3 6E CC     	JP PLAY
  87+ C412 18 25        	JR MUTE
  88+ C414 10           SETUP	DB %00010000 ;set bit0, if you want to play without looping
  89+ C415              	     ;(optional);
  90+ C415              	     ;set bit1 for PT2 and reset for PT3 before
  91+ C415              	     ;calling INIT;
  92+ C415              	     ;bits2-3: %00-ABC, %01-ACB, %10-BAC (optional);
  93+ C415              	     ;bits4-5: %00-no TS, %01-2 modules TS, %10-
  94+ C415              	     ;autodetect PT3 TS-format by AlCo (PT 3.7+);
  95+ C415              	     ;Remark: old PT3 TS-format by AlCo (PT 3.6) is not
  96+ C415              	     ;documented and must be converted to new standard.
  97+ C415              	     ;bit6 is set each time, when loop point of 2nd TS
  98+ C415              	     ;module is passed (optional).
  99+ C415              	     ;bit7 is set each time, when loop point of 1st TS
 100+ C415              	     ;or of single module is passed (optional).
 101+ C415
